{
  "name": "vite-project-version-two",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:js && npm run build:css",
    "build:js": "esbuild src/main.js --bundle --outfile=public/main.js --minify --sourcemap",
    "build:css": "sass src/styles/main.scss src/styles/main.css --no-source-map && tailwindcss -i src/styles/main.css -o public/tailwind.css --minify",
    "dev:css": "concurrently \"sass --watch src/styles/main.scss:src/styles/main.css\" \"tailwindcss -i src/styles/main.css -o public/tailwind.css --watch\"",
    "preview": "vite preview"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.2",
    "postcss": "^8.5.6",
    "sass": "^1.97.3",
    "tailwindcss": "^3.4.8",
    "vite": "^7.2.4"
  }
}
